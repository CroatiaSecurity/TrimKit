<Window x:Class="TrimKit.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:TrimKit.Converters"
        Title="TrimKit — Windows Image Customization" 
        Height="800" Width="1250"
        MinHeight="680" MinWidth="1050"
        WindowStartupLocation="CenterScreen"
        Background="#FF202124"
        FontFamily="Segoe UI Variable, Segoe UI"
        FontSize="13">

    <Window.Resources>
        <converters:LogLevelToBrushConverter x:Key="LogLevelToBrush"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
        <converters:IndexToVisibilityConverter x:Key="IndexToVis"/>

        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Background" Value="#35363A"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#3C4043"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#444750"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5F6368"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ChromeButton}">
            <Setter Property="Background" Value="#8AB4F8"/>
            <Setter Property="Foreground" Value="#202124"/>
            <Setter Property="BorderBrush" Value="#8AB4F8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="GreenButton" TargetType="Button" BasedOn="{StaticResource ChromeButton}">
            <Setter Property="Background" Value="#81C995"/>
            <Setter Property="Foreground" Value="#202124"/>
            <Setter Property="BorderBrush" Value="#81C995"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ChromeButton}">
            <Setter Property="Background" Value="#F28B82"/>
            <Setter Property="Foreground" Value="#202124"/>
            <Setter Property="BorderBrush" Value="#F28B82"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="NavItem" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#B4B8BE"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}"
                                BorderBrush="Transparent" BorderThickness="3,0,0,0">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2D2E32"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#8AB4F8"/>
                                <Setter Property="Foreground" Value="#8AB4F8"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#28292D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#292A2D"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#3C4043"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="CaretBrush" Value="#8AB4F8"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#292A2D"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#3C4043"/>
            <Setter Property="TextElement.Foreground" Value="#FFFFFF"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#292A2D"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#444750"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#FFFFFF"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#292A2D"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#FFFFFF"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#35363A"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#FFFFFF"/>
            </Style.Resources>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#292A2D"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <!-- Placeholder panel style for unimplemented tabs -->
        <Style x:Key="PlaceholderPanel" TargetType="StackPanel">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- LEFT SIDEBAR -->
        <Border Grid.Column="0" Grid.RowSpan="2" Background="#1C1C1F" BorderBrush="#303336" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="16,16,16,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x1F9D9;" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="TrimKit" FontSize="16" FontWeight="Bold" Foreground="#8AB4F8"/>
                    </StackPanel>
                    <TextBlock Text="v0.0.5" Foreground="#5F6368" FontSize="10" Margin="28,2,0,0"/>
                </StackPanel>

                <ListBox Grid.Row="1" Background="Transparent" BorderThickness="0"
                         ItemContainerStyle="{StaticResource NavItem}"
                         SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
                    <ListBoxItem Content="&#x2B07;  Source / ISO"/>
                    <ListBoxItem Content="&#x1F4E6;  Updates"/>
                    <ListBoxItem Content="&#x1F4F1;  Apps"/>
                    <ListBoxItem Content="&#x1F524;  Fonts"/>
                    <ListBoxItem Content="&#x2328;  Keyboards"/>
                    <ListBoxItem Content="&#x1F310;  Languages"/>
                    <ListBoxItem Content="&#x1F4BE;  Drivers"/>
                    <ListBoxItem Content="&#x2699;  Features"/>
                    <ListBoxItem Content="&#x1F6E0;  Services"/>
                    <ListBoxItem Content="&#x1F5D1;  Components"/>
                    <ListBoxItem Content="&#x1F527;  Tweaks"/>
                    <ListBoxItem Content="&#x1F3A8;  Customize"/>
                    <ListBoxItem Content="&#x1F4DD;  Unattend"/>
                    <ListBoxItem Content="&#x1F6E1;  Compatibility"/>
                    <ListBoxItem Content="&#x25B6;  Apply"/>
                    <ListBoxItem Content="&#x1F4CB;  Log"/>
                </ListBox>

                <Border Grid.Row="2" Background="#28292D" Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="{Binding StatusText}" Foreground="#80868E" FontSize="10.5"
                                   TextTrimming="CharacterEllipsis"/>
                        <ProgressBar Value="{Binding ProgressValue}" Height="3" Margin="0,6,0,0"
                                     Background="#35363A" Foreground="#8AB4F8" BorderThickness="0"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- RIGHT CONTENT -->
        <Grid Grid.Column="1" Grid.Row="0" Background="#202124">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TOP TOOLBAR -->
            <Border Grid.Row="0" Background="#28292D" BorderBrush="#303336" BorderThickness="0,0,0,1" Padding="16,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Image:" Foreground="#80868E" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Text="{Binding WimFilePath}" Width="320" IsReadOnly="True" VerticalAlignment="Center"/>
                    <Button Content="Browse" Command="{Binding BrowseWimCommand}" 
                            Style="{StaticResource ChromeButton}" Margin="8,0"/>
                    <ComboBox ItemsSource="{Binding WimImages}" SelectedItem="{Binding SelectedImage}"
                              DisplayMemberPath="DisplayName" Width="200" VerticalAlignment="Center" Margin="8,0"/>
                    <Button Content="Mount" Command="{Binding MountImageCommand}" 
                            Style="{StaticResource AccentButton}" Margin="8,0"
                            IsEnabled="{Binding IsMounted, Converter={StaticResource InverseBool}}"/>
                    <Button Content="Save" Command="{Binding UnmountCommand}" CommandParameter="True"
                            Style="{StaticResource GreenButton}" Margin="4,0"
                            IsEnabled="{Binding IsMounted}"/>
                    <Button Content="Discard" Command="{Binding UnmountCommand}" CommandParameter="False"
                            Style="{StaticResource DangerButton}" Margin="4,0"
                            IsEnabled="{Binding IsMounted}"/>
                </StackPanel>
            </Border>

            <!-- TAB CONTENT PANELS -->
            <Grid Grid.Row="1">

                <!-- Tab 0: Source / ISO -->
                <Grid Margin="30,30,30,30" DataContext="{Binding DownloadViewModel}"
                      Visibility="{Binding DataContext.SelectedTabIndex, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource IndexToVis}, ConverterParameter=0}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="650">
                        <TextBlock Text="Get a Windows ISO" Foreground="#FFFFFF" FontSize="18" FontWeight="SemiBold" 
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Download an ISO from one of these sources, then click Browse to load it." 
                                   Foreground="#80868E" FontSize="12.5" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                        <TextBlock Text="Official" Foreground="#5F6368" FontSize="10.5" Margin="0,0,0,8"/>
                        <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                            <Button Content="Microsoft (Win11)" Command="{Binding OpenMicrosoftPageCommand}" 
                                    Style="{StaticResource ChromeButton}" Margin="4" Padding="18,10" FontSize="12"/>
                            <Button Content="Microsoft (Win10)" Command="{Binding OpenMicrosoft10PageCommand}" 
                                    Style="{StaticResource ChromeButton}" Margin="4" Padding="18,10" FontSize="12"/>
                        </WrapPanel>

                        <TextBlock Text="Third-party mirrors &amp; tools" Foreground="#5F6368" FontSize="10.5" Margin="0,0,0,8"/>
                        <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                            <Button Content="UUP dump" Command="{Binding OpenUupDumpCommand}" 
                                    Style="{StaticResource ChromeButton}" Margin="4" Padding="18,10" FontSize="12"/>
                            <Button Content="Adguard TechBench" Command="{Binding OpenAdguardTechBenchCommand}" 
                                    Style="{StaticResource ChromeButton}" Margin="4" Padding="18,10" FontSize="12"/>
                            <Button Content="Adguard UUP" Command="{Binding OpenAdguardUupCommand}" 
                                    Style="{StaticResource ChromeButton}" Margin="4" Padding="18,10" FontSize="12"/>
                            <Button Content="Heidoc" Command="{Binding OpenHeidocCommand}" 
                                    Style="{StaticResource ChromeButton}" Margin="4" Padding="18,10" FontSize="12"/>
                            <Button Content="OS.click" Command="{Binding OpenOsClickCommand}" 
                                    Style="{StaticResource ChromeButton}" Margin="4" Padding="18,10" FontSize="12"/>
                            <Button Content="GetMyOS" Command="{Binding OpenGetMyOsCommand}" 
                                    Style="{StaticResource ChromeButton}" Margin="4" Padding="18,10" FontSize="12"/>
                            <Button Content="Bob Pony" Command="{Binding OpenBobPonyCommand}" 
                                    Style="{StaticResource ChromeButton}" Margin="4" Padding="18,10" FontSize="12"/>
                            <Button Content="massgrave" Command="{Binding OpenMassgraveCommand}" 
                                    Style="{StaticResource ChromeButton}" Margin="4" Padding="18,10" FontSize="12"/>
                        </WrapPanel>

                        <TextBlock Text="USB boot tool" Foreground="#5F6368" FontSize="10.5" Margin="0,0,0,8"/>
                        <WrapPanel HorizontalAlignment="Center">
                            <Button Content="Rufus" Command="{Binding OpenRufusCommand}" 
                                    Style="{StaticResource ChromeButton}" Margin="4" Padding="18,10" FontSize="12"/>
                        </WrapPanel>
                    </StackPanel>
                </Grid>

                <!-- Tab 1: Updates -->
                <Grid Margin="16" Visibility="{Binding SelectedTabIndex, Converter={StaticResource IndexToVis}, ConverterParameter=1}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="Available Updates from Microsoft Update Catalog" Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock Text="Fetches updates matching your mounted edition and build. Check updates to integrate via Apply All." 
                                   Foreground="#80868E" FontSize="11.5"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Fetch Available Updates" Command="{Binding FetchUpdatesCommand}" 
                                Style="{StaticResource AccentButton}" IsEnabled="{Binding IsMounted}"/>
                        <TextBlock Text="Requires internet • Filters to mounted build + architecture" 
                                   Foreground="#5F6368" FontSize="10.5" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>
                    <ListBox Grid.Row="2" ItemsSource="{Binding AvailableUpdates}" Background="#1C1C1F" BorderBrush="#303336">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected}" Foreground="#E8EAED" Margin="4,3">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" Foreground="#E8EAED" TextWrapping="Wrap"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding Size}" Foreground="#81C995" FontSize="11"/>
                                            <TextBlock Text="{Binding Classification}" Foreground="#5F6368" FontSize="11" Margin="12,0,0,0"/>
                                            <TextBlock Text="{Binding LastUpdated}" Foreground="#5F6368" FontSize="11" Margin="12,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </CheckBox>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock Grid.Row="3" Foreground="#5F6368" FontSize="10.5" Margin="0,6,0,0"
                               Text="Selected updates will be downloaded and integrated during Apply All. Requires intact servicing stack in the image."/>
                </Grid>

                <!-- Tab 2: Apps -->
                <Grid Margin="16" Visibility="{Binding SelectedTabIndex, Converter={StaticResource IndexToVis}, ConverterParameter=2}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Provisioned Apps — check items to remove" Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ListBox Grid.Row="1" ItemsSource="{Binding ProvisionedApps}" Background="#1C1C1F" BorderBrush="#303336">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected}" Foreground="#E8EAED" Margin="4,3">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding DisplayName}" Foreground="#E8EAED"/>
                                        <TextBlock Text="{Binding SizeDisplay}" Foreground="#5F6368" Margin="12,0,0,0"/>
                                    </StackPanel>
                                </CheckBox>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- Tab 3: Fonts -->
                <Grid Margin="16" Visibility="{Binding SelectedTabIndex, Converter={StaticResource IndexToVis}, ConverterParameter=3}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Fonts — check to remove (system fonts protected)" Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Fonts}" Background="#1C1C1F" BorderBrush="#303336">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected}" IsEnabled="{Binding IsProtected, Converter={StaticResource InverseBool}}" Foreground="#E8EAED" Margin="4,3">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding DisplayName}" Foreground="#E8EAED"/>
                                        <TextBlock Text="{Binding SizeDisplay}" Foreground="#5F6368" Margin="12,0,0,0"/>
                                        <TextBlock Text="🔒" Visibility="{Binding IsProtected, Converter={StaticResource BoolToVis}}" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </CheckBox>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- Tab 4: Keyboards -->
                <Grid Margin="16" Visibility="{Binding SelectedTabIndex, Converter={StaticResource IndexToVis}, ConverterParameter=4}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Keyboard Layouts — check to remove" Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ListBox Grid.Row="1" ItemsSource="{Binding KeyboardLayouts}" Background="#1C1C1F" BorderBrush="#303336">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected}" Foreground="#E8EAED" Margin="4,3">
                                    <TextBlock Text="{Binding DisplayName}" Foreground="#E8EAED"/>
                                </CheckBox>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- Tab 5: Languages -->
                <Grid Margin="16" Visibility="{Binding SelectedTabIndex, Converter={StaticResource IndexToVis}, ConverterParameter=5}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Languages — check to remove" Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Languages}" Background="#1C1C1F" BorderBrush="#303336">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected}" Foreground="#E8EAED" Margin="4,3">
                                    <TextBlock Text="{Binding DisplayName}" Foreground="#E8EAED"/>
                                </CheckBox>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- Tab 6: Drivers -->
                <Grid Margin="16" Visibility="{Binding SelectedTabIndex, Converter={StaticResource IndexToVis}, ConverterParameter=6}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Drivers — add folders to inject, check inbox drivers to remove" Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Add Driver Folder" Command="{Binding AddDriverPathCommand}" Style="{StaticResource ChromeButton}"/>
                        <ItemsControl ItemsSource="{Binding DriverPaths}" Margin="12,0,0,0">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#35363A" CornerRadius="4" Padding="8,4" Margin="4,0">
                                        <TextBlock Text="{Binding}" Foreground="#E8EAED" FontSize="11"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                    <ListBox Grid.Row="2" ItemsSource="{Binding InboxDrivers}" Background="#1C1C1F" BorderBrush="#303336">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected}" Foreground="#E8EAED" Margin="4,3">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding DisplayName}" Foreground="#E8EAED"/>
                                        <TextBlock Text="{Binding Category}" Foreground="#5F6368" Margin="12,0,0,0"/>
                                        <TextBlock Text="{Binding SizeDisplay}" Foreground="#5F6368" Margin="12,0,0,0"/>
                                    </StackPanel>
                                </CheckBox>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- Tab 7: Features -->
                <Grid Margin="16" Visibility="{Binding SelectedTabIndex, Converter={StaticResource IndexToVis}, ConverterParameter=7}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Windows Features — toggle enable/disable" Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Features}" Background="#1C1C1F" BorderBrush="#303336">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsEnabled}" Foreground="#E8EAED" Margin="4,3">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding FeatureName}" Foreground="#E8EAED"/>
                                        <TextBlock Text="{Binding State}" Foreground="#5F6368" Margin="12,0,0,0"/>
                                    </StackPanel>
                                </CheckBox>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- Tab 8: Services -->
                <Grid Margin="16" Visibility="{Binding SelectedTabIndex, Converter={StaticResource IndexToVis}, ConverterParameter=8}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Services — check to disable" Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Load Services" Command="{Binding LoadServicesCommand}" 
                                Style="{StaticResource ChromeButton}" IsEnabled="{Binding IsMounted}"/>
                        <TextBlock Text="Scans offline registry (may take a few seconds)" 
                                   Foreground="#5F6368" FontSize="10.5" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>
                    <ListBox Grid.Row="2" ItemsSource="{Binding Services}" Background="#1C1C1F" BorderBrush="#303336">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected}" Foreground="#E8EAED" Margin="4,3">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding DisplayName}" Foreground="#E8EAED" Width="280"/>
                                        <TextBlock Text="{Binding ServiceName}" Foreground="#5F6368" Width="200"/>
                                        <TextBlock Text="{Binding StartType}" Foreground="#80868E"/>
                                    </StackPanel>
                                </CheckBox>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- Tab 9: Components (ALL removable items grouped by category) -->
                <Grid Margin="16" Visibility="{Binding SelectedTabIndex, Converter={StaticResource IndexToVis}, ConverterParameter=9}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="All Components — grouped by category" Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock Text="Check items to remove. Use Select All per category. SafetyGuard protects critical items." 
                                   Foreground="#80868E" FontSize="11.5"/>
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Apps -->
                            <Expander Header="{Binding ProvisionedApps.Count, StringFormat='Apps ({0})'}" Foreground="#8AB4F8" IsExpanded="True" Margin="0,0,0,4">
                                <StackPanel>
                                    <Button Content="Select All Apps" Style="{StaticResource ChromeButton}" Padding="8,3" HorizontalAlignment="Left" Margin="0,4,0,4"
                                            Command="{Binding SelectAllAppsCommand}"/>
                                    <ItemsControl ItemsSource="{Binding ProvisionedApps}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected}" Foreground="#E8EAED" Margin="16,2,0,2">
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="#E8EAED"/>
                                                </CheckBox>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Expander>
                            <!-- Capabilities -->
                            <Expander Header="{Binding Capabilities.Count, StringFormat='Capabilities ({0})'}" Foreground="#8AB4F8" Margin="0,0,0,4">
                                <StackPanel>
                                    <Button Content="Select All Capabilities" Style="{StaticResource ChromeButton}" Padding="8,3" HorizontalAlignment="Left" Margin="0,4,0,4"
                                            Command="{Binding SelectAllCapabilitiesCommand}"/>
                                    <ItemsControl ItemsSource="{Binding Capabilities}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected}" Foreground="#E8EAED" Margin="16,2,0,2">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding DisplayName}" Foreground="#E8EAED"/>
                                                        <TextBlock Text="{Binding Category}" Foreground="#5F6368" Margin="12,0,0,0" FontSize="11"/>
                                                    </StackPanel>
                                                </CheckBox>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Expander>
                            <!-- Fonts -->
                            <Expander Header="{Binding Fonts.Count, StringFormat='Fonts ({0})'}" Foreground="#8AB4F8" Margin="0,0,0,4">
                                <StackPanel>
                                    <Button Content="Select All Fonts" Style="{StaticResource ChromeButton}" Padding="8,3" HorizontalAlignment="Left" Margin="0,4,0,4"
                                            Command="{Binding SelectAllFontsCommand}"/>
                                    <ItemsControl ItemsSource="{Binding Fonts}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected}" IsEnabled="{Binding IsProtected, Converter={StaticResource InverseBool}}" 
                                                          Foreground="#E8EAED" Margin="16,2,0,2">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding DisplayName}" Foreground="#E8EAED"/>
                                                        <TextBlock Text="🔒" Visibility="{Binding IsProtected, Converter={StaticResource BoolToVis}}" Margin="6,0,0,0"/>
                                                    </StackPanel>
                                                </CheckBox>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Expander>
                            <!-- Keyboard Layouts -->
                            <Expander Header="{Binding KeyboardLayouts.Count, StringFormat='Keyboard Layouts ({0})'}" Foreground="#8AB4F8" Margin="0,0,0,4">
                                <StackPanel>
                                    <Button Content="Select All Keyboards" Style="{StaticResource ChromeButton}" Padding="8,3" HorizontalAlignment="Left" Margin="0,4,0,4"
                                            Command="{Binding SelectAllKeyboardsCommand}"/>
                                    <ItemsControl ItemsSource="{Binding KeyboardLayouts}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected}" Foreground="#E8EAED" Margin="16,2,0,2">
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="#E8EAED"/>
                                                </CheckBox>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Expander>
                            <!-- Languages -->
                            <Expander Header="{Binding Languages.Count, StringFormat='Languages ({0})'}" Foreground="#8AB4F8" Margin="0,0,0,4">
                                <StackPanel>
                                    <Button Content="Select All Languages" Style="{StaticResource ChromeButton}" Padding="8,3" HorizontalAlignment="Left" Margin="0,4,0,4"
                                            Command="{Binding SelectAllLanguagesCommand}"/>
                                    <ItemsControl ItemsSource="{Binding Languages}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected}" Foreground="#E8EAED" Margin="16,2,0,2">
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="#E8EAED"/>
                                                </CheckBox>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Expander>
                            <!-- Inbox Drivers -->
                            <Expander Header="{Binding InboxDrivers.Count, StringFormat='Inbox Drivers ({0})'}" Foreground="#8AB4F8" Margin="0,0,0,4">
                                <StackPanel>
                                    <Button Content="Select All Drivers" Style="{StaticResource ChromeButton}" Padding="8,3" HorizontalAlignment="Left" Margin="0,4,0,4"
                                            Command="{Binding SelectAllDriversCommand}"/>
                                    <ItemsControl ItemsSource="{Binding InboxDrivers}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected}" Foreground="#E8EAED" Margin="16,2,0,2">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding DisplayName}" Foreground="#E8EAED"/>
                                                        <TextBlock Text="{Binding Category}" Foreground="#5F6368" Margin="12,0,0,0" FontSize="11"/>
                                                        <TextBlock Text="{Binding SizeDisplay}" Foreground="#5F6368" Margin="12,0,0,0" FontSize="11"/>
                                                    </StackPanel>
                                                </CheckBox>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- Tab 10: Tweaks -->
                <Grid Margin="16" Visibility="{Binding SelectedTabIndex, Converter={StaticResource IndexToVis}, ConverterParameter=10}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Registry Tweaks — check to apply" Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ListBox Grid.Row="1" ItemsSource="{Binding RegistryTweaks}" Background="#1C1C1F" BorderBrush="#303336">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected}" Foreground="#E8EAED" Margin="4,3">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" Foreground="#E8EAED"/>
                                        <TextBlock Text="{Binding Category}" Foreground="#5F6368" Margin="12,0,0,0"/>
                                    </StackPanel>
                                </CheckBox>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- Tab 11: Customize -->
                <Grid Margin="16" Visibility="{Binding SelectedTabIndex, Converter={StaticResource IndexToVis}, ConverterParameter=11}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Customize — wallpapers, branding, scripts" Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <StackPanel Grid.Row="1" MaxWidth="600" HorizontalAlignment="Left">
                        <TextBlock Text="Wallpapers" Foreground="#8AB4F8" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock Text="Set desktop, lock screen, or setup wallpapers via Load Preset or Apply All with a .wwp preset that includes customization paths." 
                                   Foreground="#80868E" FontSize="11.5" TextWrapping="Wrap" Margin="0,0,0,16"/>

                        <TextBlock Text="OEM Branding" Foreground="#8AB4F8" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock Text="Manufacturer, model, support URL, and logo can be set via presets. These appear in System &gt; About after install." 
                                   Foreground="#80868E" FontSize="11.5" TextWrapping="Wrap" Margin="0,0,0,16"/>

                        <TextBlock Text="Post-Install Scripts" Foreground="#8AB4F8" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock Text="SetupComplete.cmd and FirstLogon scripts can be injected via presets. These run automatically after Windows installs." 
                                   Foreground="#80868E" FontSize="11.5" TextWrapping="Wrap" Margin="0,0,0,16"/>

                        <TextBlock Text="Cleanup" Foreground="#8AB4F8" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock Text="DISM image cleanup and Compact OS run automatically at the end of Apply All to shrink the final WIM." 
                                   Foreground="#80868E" FontSize="11.5" TextWrapping="Wrap" Margin="0,0,0,16"/>

                        <TextBlock Text="All customization options are applied during the Apply All phase.&#x0a;Create or load a .wwp preset to configure these settings." 
                                   Foreground="#5F6368" FontSize="11" TextWrapping="Wrap" FontStyle="Italic"/>
                    </StackPanel>
                </Grid>

                <!-- Tab 12: Unattend -->
                <Grid Margin="16" Visibility="{Binding SelectedTabIndex, Converter={StaticResource IndexToVis}, ConverterParameter=12}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Autounattend Generator" Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel MaxWidth="550" HorizontalAlignment="Left" DataContext="{Binding UnattendConfig}">
                            <!-- Locale -->
                            <TextBlock Text="Locale" Foreground="#8AB4F8" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Language:" Foreground="#B4B8BE" Width="120" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Language, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Input Locale:" Foreground="#B4B8BE" Width="120" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding InputLocale, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Time Zone:" Foreground="#B4B8BE" Width="120" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding TimeZone, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="Computer Name:" Foreground="#B4B8BE" Width="120" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding ComputerName, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                            </StackPanel>

                            <!-- User -->
                            <TextBlock Text="User Account" Foreground="#8AB4F8" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Username:" Foreground="#B4B8BE" Width="120" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Password:" Foreground="#B4B8BE" Width="120" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                            </StackPanel>
                            <CheckBox Content="Auto-logon after install" IsChecked="{Binding AutoLogon}" Foreground="#E8EAED" Margin="0,4"/>
                            <CheckBox Content="Enable built-in Administrator account" IsChecked="{Binding EnableAdminAccount}" Foreground="#E8EAED" Margin="0,4,0,12"/>

                            <!-- OOBE -->
                            <TextBlock Text="OOBE (Out-of-Box Experience)" Foreground="#8AB4F8" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <CheckBox Content="Skip OOBE entirely (no MS account, no privacy questions)" IsChecked="{Binding SkipOobe}" Foreground="#E8EAED" Margin="0,4"/>
                            <CheckBox Content="Hide EULA page" IsChecked="{Binding HideEula}" Foreground="#E8EAED" Margin="0,4"/>
                            <CheckBox Content="Hide wireless setup" IsChecked="{Binding HideWirelessSetup}" Foreground="#E8EAED" Margin="0,4"/>
                            <CheckBox Content="Disable telemetry" IsChecked="{Binding DisableTelemetry}" Foreground="#E8EAED" Margin="0,4,0,12"/>

                            <!-- Win11 Bypass -->
                            <TextBlock Text="Windows 11 Bypass" Foreground="#8AB4F8" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <CheckBox Content="Bypass TPM 2.0 check" IsChecked="{Binding BypassTpmCheck}" Foreground="#E8EAED" Margin="0,4"/>
                            <CheckBox Content="Bypass Secure Boot check" IsChecked="{Binding BypassSecureBootCheck}" Foreground="#E8EAED" Margin="0,4"/>
                            <CheckBox Content="Bypass RAM check" IsChecked="{Binding BypassRamCheck}" Foreground="#E8EAED" Margin="0,4,0,12"/>

                            <!-- System -->
                            <TextBlock Text="System" Foreground="#8AB4F8" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <CheckBox Content="Disable Windows Defender" IsChecked="{Binding DisableDefender}" Foreground="#E8EAED" Margin="0,4"/>
                            <CheckBox Content="Disable UAC" IsChecked="{Binding DisableUac}" Foreground="#E8EAED" Margin="0,4"/>
                            <CheckBox Content="Disable hibernation" IsChecked="{Binding DisableHibernation}" Foreground="#E8EAED" Margin="0,4"/>
                            <CheckBox Content="Compact OS (smaller install footprint)" IsChecked="{Binding CompactOs}" Foreground="#E8EAED" Margin="0,4,0,12"/>

                            <TextBlock Text="Settings are injected into the image during Apply All." 
                                       Foreground="#5F6368" FontSize="11" FontStyle="Italic" Margin="0,8,0,0"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- Tab 13: Compatibility -->
                <Grid Margin="16" Visibility="{Binding SelectedTabIndex, Converter={StaticResource IndexToVis}, ConverterParameter=13}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Safety — check areas to PROTECT from removal" Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Grid.Row="1" Text="Checked = protected (won't be removed). Unchecked = can be removed by Apply All." 
                               Foreground="#80868E" FontSize="11.5" Margin="0,0,0,8"/>
                    <ListBox Grid.Row="2" ItemsSource="{Binding CompatibilityOptions}" Background="#1C1C1F" BorderBrush="#303336">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsEnabled}" Foreground="#E8EAED" Margin="4,2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" Foreground="#E8EAED"/>
                                        <TextBlock Text="{Binding Category}" Foreground="#5F6368" Margin="12,0,0,0" FontSize="11"/>
                                    </StackPanel>
                                </CheckBox>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock Grid.Row="3" Text="Boot.wim protections:" Foreground="#8AB4F8" FontSize="12" FontWeight="SemiBold" Margin="0,8,0,4"/>
                    <ListBox Grid.Row="4" ItemsSource="{Binding BootCompatibilityOptions}" Background="#1C1C1F" BorderBrush="#303336" MaxHeight="150">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsEnabled}" Foreground="#E8EAED" Margin="4,2">
                                    <TextBlock Text="{Binding Name}" Foreground="#E8EAED"/>
                                </CheckBox>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- Tab 14: Apply -->
                <Grid Margin="16" Visibility="{Binding SelectedTabIndex, Converter={StaticResource IndexToVis}, ConverterParameter=14}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Apply All — execution pipeline" Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <StackPanel Grid.Row="1" MaxWidth="650" HorizontalAlignment="Left">
                        <TextBlock Text="Click Apply All in the bottom bar to run the full pipeline:" 
                                   Foreground="#B4B8BE" FontSize="12" Margin="0,0,0,12"/>
                        <TextBlock Foreground="#80868E" FontSize="11.5" TextWrapping="Wrap"
                                   Text="1. Remove selected DISM packages&#x0a;2. Enable/disable features&#x0a;3. Apply registry tweaks&#x0a;4. Inject drivers&#x0a;5. Remove selected components (apps, capabilities, fonts, keyboards, languages, inbox drivers)&#x0a;6. Configure services&#x0a;7. WinSxS component store cleanup&#x0a;8. DISM image cleanup (shrink WIM)&#x0a;9. Repeat for boot.wim (with stricter BootWimSafetyGuard)&#x0a;10. Unmount and save both images&#x0a;11. Delete temp work folder"/>
                        <TextBlock Text="After Apply All completes, all resources are cleaned up automatically." 
                                   Foreground="#5F6368" FontSize="11" Margin="0,16,0,0" FontStyle="Italic"/>
                    </StackPanel>
                </Grid>

                <!-- Tab 15: Log -->
                <Grid Margin="16"
                      Visibility="{Binding SelectedTabIndex, Converter={StaticResource IndexToVis}, ConverterParameter=15}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Operation Log" Foreground="#FFFFFF" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <ListBox Grid.Row="1" ItemsSource="{Binding LogEntries}" Background="#1C1C1F" BorderBrush="#303336"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Message}" Foreground="{Binding Level, Converter={StaticResource LogLevelToBrush}}"
                                           FontSize="11.5" FontFamily="Cascadia Mono, Consolas" TextWrapping="Wrap" Margin="4,2"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Grid.Row="2" Content="Clear Log" Command="{Binding ClearLogCommand}" 
                            Style="{StaticResource ChromeButton}" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                </Grid>

            </Grid>
        </Grid>

        <!-- BOTTOM BAR -->
        <Border Grid.Column="1" Grid.Row="1" Background="#28292D" BorderBrush="#303336" BorderThickness="0,1,0,0" Padding="16,9">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save Preset" Command="{Binding SavePresetCommand}"
                        Style="{StaticResource ChromeButton}" Margin="4,0"/>
                <Button Content="Load Preset" Command="{Binding LoadPresetCommand}"
                        Style="{StaticResource ChromeButton}" Margin="4,0"/>
                <Button Content="Apply All" Command="{Binding ApplyChangesCommand}"
                        Style="{StaticResource AccentButton}" Margin="12,0,0,0"
                        IsEnabled="{Binding IsMounted}" Padding="20,8"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
